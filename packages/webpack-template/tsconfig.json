{
  "compilerOptions": {
    "target": "es6",
    "jsx": "react",
    "lib": [
      "DOM",
      "ESNext",
      "ES2021"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "strict": true,
    "declaration": false,
    "importHelpers": true,
    "outDir": "./dist",
    "removeComments": true,
    "sourceMap": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "skipLibCheck": true
  },
  "include": [
    "./src/**/*",
    "index.d.ts",
    "vitest.config.ts",
    "vitest.setup.ts"
  ],
  "exclude": [
    "node_modules",
    "build",
    "coverage",
    "dist",
    "typings"
  ]
}
