{
  "name": "create-bod-app",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.15.1",
  "description": "Boilerplate CLI App",
  "author": "sabertazimi <sabertazimi@gmail.com>",
  "license": "MIT",
  "homepage": "https://tazimi.dev/bod",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sabertazimi/bod.git"
  },
  "bugs": {
    "url": "https://github.com/sabertazimi/bod/issues"
  },
  "keywords": [
    "bod",
    "bod-cli",
    "boilerplate",
    "cli",
    "starter",
    "starter-kit",
    "template",
    "typescript",
    "eslint",
    "eslint-config",
    "stylelint",
    "stylelint-config",
    "vite"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "pnpm dev:bod",
    "dev:all": "pnpm -r run dev",
    "dev:bod": "pnpm --filter bod dev",
    "badge": "node scripts/badge.ts",
    "build": "pnpm -r run build",
    "build:docs": "pnpm --filter bod-website build:docs",
    "canary": "node scripts/canary.ts",
    "format": "pnpm -r run format",
    "lint": "pnpm -r run lint",
    "lint:fix": "pnpm -r run lint:fix",
    "lint:report": "pnpm -r run lint:report",
    "release": "node scripts/release.ts --push",
    "test": "vitest",
    "test:all": "pnpm -r run test && vitest run --coverage"
  },
  "devDependencies": {
    "@dg-scripts/eslint-config": "workspace:^",
    "@dg-scripts/stylelint-config": "workspace:^",
    "@types/node": "^24.13.3",
    "@types/semver": "^7.7.1",
    "@vitest/coverage-v8": "^4.1.10",
    "chalk": "^4.1.2",
    "chokidar": "^5.0.0",
    "ci-info": "^4.4.0",
    "concurrently": "^10.0.3",
    "consola": "^3.4.2",
    "dotenv": "^17.4.2",
    "eslint": "^10.7.0",
    "lerna": "^9.0.7",
    "prettier": "^3.9.5",
    "semver": "^7.8.5",
    "stylelint": "^17.14.1",
    "tslib": "^2.8.1",
    "typescript": "^7.0.2",
    "undici": "^8.7.0",
    "vitest": "^4.1.10"
  }
}
