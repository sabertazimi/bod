osition":[[0,6]]},"78":{"position":[[0,6]]}}}]],"pipeline":["stemmer"]}},{"documents":[],"index":{"version":"2.3.9","fields":["t"],"fieldVectors":[],"invertedIndex":[],"pipeline":["stemmer"]}},{"documents":[{"i":2,"t":"Boilerplate CLI App - Create a new project powered by Create React App and @sabertazimi/react-scripts.","s":"Bod CLI","u":"/bod/docs/bod","h":"","p":1},{"i":4,"t":"# Global installation npm i -g bod # Local installation npm i -D bod","s":"Installation","u":"/bod/docs/bod","h":"#installation","p":1},{"i":6,"t":"bod create <appName> Usage: bod <command> [options] Options: -v, --version output the version number -h, --help display help for command Commands: create|c <appName> Create a new project powered by @sabertazimi/react-scripts info|i Print debugging information about your environment help [command] display help for command ℹ Run bod <command> --help for detailed usage of given command.","s":"Usage","u":"/bod/docs/bod","h":"#usage","p":1},{"i":8,"t":"Usage: create|c [options] <appName> create a new project powered by @sabertazimi/react-scripts Options: -h, --help display help for command","s":"bod create","u":"/bod/docs/bod","h":"#bod-create","p":1},{"i":10,"t":"Usage: info|i [options] print debugging information about your environment Options: -h, --help display help for command","s":"bod info","u":"/bod/docs/bod","h":"#bod-info","p":1},{"i":13,"t":"This package includes the shareable ESLint configuration used by Bod CLI.","s":"@dg-scripts/eslint-config","u":"/bod/docs/eslint-config","h":"","p":12},{"i":15,"t":"npm install -D @dg-scripts/eslint-config","s":"Installation","u":"/bod/docs/eslint-config","h":"#installation","p":12},{"i":17,"t":"Create a file named eslint.config.js with following contents in the root folder of your project: export { default } from '@dg-scripts/eslint-config' You can override the settings from @dg-scripts/eslint-config by editing the eslint.config.js file: import eslintConfig from '@dg-scripts/eslint-config' export default eslintConfig.append( { ignores: ['cypress', 'cypress.config.ts'], }, ).append({ rules: { 'react-refresh/only-export-components': 'off', }, })","s":"Usage","u":"/bod/docs/eslint-config","h":"#usage","p":12},{"i":19,"t":"When package next and eslint-config-next installed in project, eslint configuration will enable automatically, no need for any additional configuration.","s":"Next.js","u":"/bod/docs/eslint-config","h":"#nextjs","p":12},{"i":21,"t":"Type aware rules can opt-out by: export { disableTypeAware as default } from '@dg-scripts/eslint-config'","s":"Disable Type Aware Rules","u":"/bod/docs/eslint-config","h":"#disable-type-aware-rules","p":12},{"i":24,"t":"This package includes the shareable ESLint configuration used by Bod CLI, original forked from Create React App. Please refer to its documentation: Getting Started: How to create a new app. User Guide: How to develop apps bootstrapped with Create React App.","s":"eslint-config-bod","u":"/bod/docs/eslint-config-bod","h":"","p":23},{"i":26,"t":"The easiest way to use this configuration is with Create React App, which includes it by default. You don’t need to install it separately in Create React App projects.","s":"Usage in Create React App Projects","u":"/bod/docs/eslint-config-bod","h":"#usage-in-create-react-app-projects","p":23},{"i":28,"t":"If you want to use this ESLint configuration in a project, you can install it with the following steps. First, install this package and ESLint. npm i -D eslint-config-bod Then create a file named eslint.config.js with following contents in the root folder of your project: import eslintConfigBod from 'eslint-config-bod' export default [...eslintConfigBod] That's it! You can override the settings from eslint-config-bod by editing the eslint.config.js file. Learn more about configuring ESLint on the ESLint website.","s":"Usage Outside of Create React App","u":"/bod/docs/eslint-config-bod","h":"#usage-outside-of-create-react-app","p":23},{"i":30,"t":"This config also ships with optional Jest rules for ESLint (based on eslint-plugin-jest). You can enable these rules by adding the Jest config to the extends array in your ESLint config.","s":"Jest rules","u":"/bod/docs/eslint-config-bod","h":"#jest-rules","p":23},{"i":32,"t":"The following rules from the eslint-plugin-jsx-a11y plugin are activated: alt-text anchor-has-content aria-activedescendant-has-tabindex aria-props aria-proptypes aria-role aria-unsupported-elements heading-has-content href-no-hash iframe-has-title img-redundant-alt no-access-key no-distracting-elements no-redundant-roles role-has-required-aria-props role-supports-aria-props scope However, if you are using Create React App and have not ejected, any additional rules will only be displayed in the IDE integrations, but not in the browser or the terminal.","s":"Accessibility Checks","u":"/bod/docs/eslint-config-bod","h":"#accessibility-checks","p":23},{"i":35,"t":"Documentation | Webpack Template","s":"Bod","u":"/bod/docs/intro","h":"","p":34},{"i":38,"t":"# Global installation npm install -g bod # Local installation npm install -D bod","s":"Installation","u":"/bod/docs/intro","h":"#installation","p":34},{"i":40,"t":"bod create <appName> bod info Usage: bod <command> [options] Options: -v, --version output the version number -h, --help display help for command Commands: create|c <appName> Create a new project powered by @sabertazimi/react-scripts info|i Print debugging information about your environment help [command] display help for command ℹ Run bod <command> --help for detailed usage of given command. More details on package bod.","s":"Usage","u":"/bod/docs/intro","h":"#usage","p":34},{"i":42,"t":"The official React template for Bod CLI.","s":"Bod Template","u":"/bod/docs/intro","h":"#bod-template","p":34},{"i":44,"t":"Webpack Template Demo.","s":"Live Demo","u":"/bod/docs/intro","h":"#live-demo","p":34},{"i":46,"t":"This template is shipped with Bod CLI out of box: # Select option `React Framework` bod create