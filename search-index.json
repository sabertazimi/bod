escript: { tsconfigPath: './path/to/tsconfig.json', }, }) To disable type-aware rules: import { defineConfig } from '@dg-scripts/eslint-config' export default defineConfig({ typescript: true, // Enable TypeScript support without type-aware rules })","s":"Type-Aware Rules","u":"/bod/docs/eslint-config","h":"#type-aware-rules","p":12},{"i":26,"t":"When package next and @next/eslint-plugin-next are installed in your project, the Next.js configuration will be enabled automatically. No additional configuration is required.","s":"Next.js","u":"/bod/docs/eslint-config","h":"#nextjs","p":12},{"i":28,"t":"See ESLint inspector report for more details.","s":"Rules","u":"/bod/docs/eslint-config","h":"#rules","p":12},{"i":31,"t":"Documentation","s":"Bod","u":"/bod/docs/intro","h":"","p":30},{"i":34,"t":"# Global installation npm install -g bod # Local installation npm install -D bod","s":"Installation","u":"/bod/docs/intro","h":"#installation","p":30},{"i":36,"t":"bod create <appName> bod info Usage: bod <command> [options] Options: -v, --version output the version number -h, --help display help for command Commands: create|c <appName> Create a new project info|i Print debugging information about your environment help [command] display help for command ℹ Run bod <command> --help for detailed usage of given command. More details on package bod.","s":"Usage","u":"/bod/docs/intro","h":"#usage","p":30},{"i":38,"t":"The official template for Bod CLI.","s":"Bod Template","u":"/bod/docs/intro","h":"#bod-template","p":30},{"i":40,"t":"bod create my-app","s":"Start with Template","u":"/bod/docs/intro","h":"#start-with-template","p":30},{"i":42,"t":"Contributions are greatly appreciated. Please fork this repository and open a pull request.","s":"Contributing","u":"/bod/docs/intro","h":"#contributing","p":30},{"i":44,"t":"@antfu/eslint-config.","s":"Credits","u":"/bod/docs/intro","h":"#credits","p":30},{"i":47,"t":"This package includes the shareable StyleLint configuration used by Bod CLI